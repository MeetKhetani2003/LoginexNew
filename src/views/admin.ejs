<!doctype html>
<html><head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Loginex Admin</title><link rel="stylesheet" href="/styles.css" /></head>
<body><section class="section"><h1>Admin Panel</h1>
<p class="tiny">Use secure ADMIN_KEY in production.</p>
<div class="grid two">
  <form method="POST" action="/admin/server?key=<%= key %>" class="card form">
    <h3>Add server machine specs</h3>
    <label>Name<input name="name" required /></label>
    <label>Region<input name="region" required /></label>
    <label>CPU<input name="cpu" required /></label>
    <label>RAM<input name="ram" required /></label>
    <label>Storage<input name="storage" required /></label>
    <label>Price monthly<input name="priceMonthly" type="number" step="0.01" required /></label>
    <label>Stock<input name="stock" type="number" required /></label>
    <input type="hidden" name="key" value="<%= key %>" />
    <button class="btn" type="submit">Publish server</button>
  </form>

  <form method="POST" action="/admin/blog?key=<%= key %>" class="card form">
    <h3>Publish blog</h3>
    <label>Title<input name="title" required /></label>
    <label>Author<input name="author" required /></label>
    <label>Content<textarea name="content" rows="8" required></textarea></label>
    <input type="hidden" name="key" value="<%= key %>" />
    <button class="btn" type="submit">Publish blog</button>
  </form>
</div>

<h2>Current inventory</h2>
<% servers.forEach(server => { %><p><strong><%= server.name %></strong> - <%= server.region %> - stock: <%= server.stock %></p><% }) %>
<h2>Rentals</h2>
<% rentals.forEach(r => { %><p><%= r.customer_name %> | <%= r.server_name %> | <%= r.status %> | expires <%= new Date(r.expires_at).toDateString() %></p><% }) %>
</section></body></html>
