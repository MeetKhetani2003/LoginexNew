<!doctype html>
<html><head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Loginex Servers</title><link rel="stylesheet" href="/styles.css" /></head>
<body><header class="nav"><div class="brand">LOGINEX</div><nav><a href="/">Home</a><a href="/blog">Blog</a></nav></header>
<section class="section"><h1>Server Inventory</h1><div class="grid">
<% servers.forEach(server => { %>
  <article class="card"><h3><%= server.name %></h3><p><%= server.region %></p><p><%= server.cpu %> • <%= server.ram %> • <%= server.storage %></p><p class="price">$<%= server.price_monthly %>/month</p><p>Available: <%= server.stock %></p><a class="btn" href="/rent/<%= server.id %>">Rent 30 days</a></article>
<% }) %>
<% if (servers.length === 0) { %><p>No servers listed yet.</p><% } %>
</div></section></body></html>
